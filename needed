CREATE TABLE producers (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    bio TEXT,
    location VARCHAR(255)
);

CREATE TABLE products (
    id INT AUTO_INCREMENT PRIMARY KEY,
    producer_id INT,
    name VARCHAR(100),
    price DECIMAL(10, 2),
    stock INT,
    traceability_info TEXT,
    FOREIGN KEY (producer_id) REFERENCES producers(id)
);


