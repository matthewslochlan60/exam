/* --- Root Variables & Base Styling --- */
:root {
    --primary-green: #00cc66;
    --dark-green: #009933;
    --border-green: #2d5a27;
    --bg-light: #f9f9f9;
    --accent-orange: #d45d00;
}

body {
    font-family: 'Segoe UI', Tahoma, sans-serif;
    line-height: 1.6;
    background-color: var(--bg-light);
    margin: 0; padding: 20px;
}

/* --- Navigation Bar --- */
ul {
    list-style-type: none;
    margin: 10px;
    padding: 0;
    overflow: hidden;
    background-color: #00ff00;
    display: flex;
    justify-content: center;
}

ul li a {
    display: block;
    color: black;
    padding: 14px 16px;
    text-decoration: none;
    font-size: 30px; 
    font-weight: bold;
}

ul li a:hover {
    background-color: #009933;
}

.active {
    text-decoration: underline;
}

/* --- Boxes and Headers --- */
.box {
    margin: auto;
    width: 80%;
    height: auto;
    background-color: lightgreen;
    border: 4px solid green;
    padding: 10px;
    text-align: center;
}

h2 {
    margin: 10px 0;
    background-color: #00cc66;
    border: 4px solid green;
    padding: 15px;
}

/* --- About Page Layout (New Additions) --- */
.producer-entry {
    display: flex;
    align-items: flex-start;
    background: white;
    border: 4px solid green;
    margin: 20px auto;
    padding: 20px;
    gap: 25px;
    width: 90%;
}

.producer-entry img {
    width: 300px;
    height: auto;
    border: 2px solid #00cc66;
}

.text-content {
    flex: 1;
}

/* --- Forms & Dashboard Panels --- */
.lbox {
    margin: 10px 0;
    width: 400px;
    height: auto;
    padding: 20px;
    background-color: #2db300;
    border: 4px solid green;
    color: white;
}

.btn {
    background-color: #b32d00;
    color: white;
    border: none;
    padding: 10px 15px;
    cursor: pointer;
    font-weight: bold;
}

/* --- Dropdowns --- */
.dropdown {
    position: relative;
    display: inline-block;
}

.dropbtn {
    background-color: #4CAF50;
    color: white;
    padding: 16px;
    font-size: 16px;
    border: none;
    cursor: pointer;
}

.dropdown-content {
    display: none;
    position: absolute;
    background-color: #f9f9f9;
    min-width: 200px;
    box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
    z-index: 1;
}

.dropdown:hover .dropdown-content {
    display: block;
}

/* --- Accessibility & Interaction --- */
button:focus, input:focus {
    outline: 3px solid var(--accent-orange);
    outline-offset: 2px;
}

button[disabled] {
    background-color: #ccc;
    cursor: not-allowed;
}
