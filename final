<?php 
session_start(); 

// --- CART LOGIC ---
// This handles the "Add to Cart" request without leaving the page
if (isset($_GET['add'])) {
    $productToAdd = $_GET['add'];
    
    if (!isset($_SESSION['cart'])) {
        $_SESSION['cart'] = [];
    }

    if (isset($_SESSION['cart'][$productToAdd])) {
        $_SESSION['cart'][$productToAdd]++;
    } else {
        $_SESSION['cart'][$productToAdd] = 1;
    }

    // Redirect back to order.php with a success flag to prevent refresh loops
    header("Location: order.php?success=" . urlencode($productToAdd));
    exit();
}
