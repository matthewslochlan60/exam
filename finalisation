        if (isset($_SESSION['cart'][$productToAdd])) {
            $_SESSION['cart'][$productToAdd]++;
        } else {
            $_SESSION['cart'][$productToAdd] = 1;
        }
    }
    // Redirect to same page to clear the GET parameter
    header("Location: cart.php");
    exit();
