session_start();
$conn = new mysqli("localhost", "root", "", "glh_database");

if (!isset($_SESSION['username']) || empty($_SESSION['cart'])) {
    header("Location: order.php");
    exit();
}

$user = $_SESSION['username'];
$method = $_POST['method'];

$products = [
    "wheat" => 2.50, "apple" => 1.25, "orange" => 1.75, "carrot" => 1.75,
    "corn" => 2.45, "sausages" => 5.00, "steak" => 6.00, "porkchop" => 6.50,
    "ham" => 1.50, "chicken" => 10.00, "bacon" => 3.85, "eggs" => 2.50
];

$total = 0;
$items_array = [];
foreach ($_SESSION['cart'] as $id => $qty) {
    if(isset($products[$id])) {
        $total += ($products[$id] * $qty);
        $items_array[] = ucfirst($id) . " (x$qty)";
    }
}

// Add delivery fee if selected
if ($method == "Delivery") { $total += 2.50; }

$items_string = implode(", ", $items_array);
$points = floor($total);

// 1. Save the Order to history
$stmt = $conn->prepare("INSERT INTO orders (username, items, total_price, delivery_method) VALUES (?, ?, ?, ?)");
$stmt->bind_param("ssds", $user, $items_string, $total, $method);
$stmt->execute();

// 2. Add Reward Points to User
$conn->query("UPDATE users SET points = points + $points WHERE username = '$user'");

// 3. Clear Cart
unset($_SESSION['cart']);

// 4. Redirect to history page
header("Location: history.php");
exit();
?>

