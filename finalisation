<script>
function confirmAdd(itemName, price) {
    // We send lowercase names to match our $products array in cart.php
    let itemKey = itemName.toLowerCase(); 
    
    let check = confirm("Would you like to add " + itemName + " (£" + price.toFixed(2) + ") to your cart?");
    if (check) {
        window.location.href = "cart.php?add=" + itemKey;
    }
}

</script>

