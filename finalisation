}

// Update quantities
if (isset($_POST['update'])) {
    foreach ($_POST['qty'] as $product => $quantity) {
        $quantity = (int)$quantity;

        if ($quantity <= 0) {
            unset($_SESSION['cart'][$product]);
        } else {
            $_SESSION['cart'][$product] = $quantity;
        }
    }

    header("Location: cart.php");
