$products = [
    "wheat" => 2.50, "sausages" => 5.00, "honey" => 3.50, "steak" => 6.00,
    "apple"=> 1.25, "porkchop" => 6.50, "ham" => 1.50, "chicken" => 10.00,
    "orange" => 1.75, "carrot" => 1.75, "bacon" => 3.85, "corn" => 2.45, "eggs" => 2.50
];

if (!isset($_SESSION['cart'])) {
    $_SESSION['cart'] = [];
}

// Handle adding items
if (isset($_GET['add'])) {
    $productToAdd = strtolower($_GET['add']); 
    if (array_key_exists($productToAdd, $products)) {
        if (isset($_SESSION['cart'][$productToAdd])) {
            $_SESSION['cart'][$productToAdd]++;
        } else {
            $_SESSION['cart'][$productToAdd] = 1;
        }
    }
    header("Location: cart.php");
    exit();
}

// Remove item
if (isset($_GET['remove'])) {
    unset($_SESSION['cart'][$_GET['remove']]);
    header("Location: cart.php");
    exit();
}

// Update quantities
if (isset($_POST['update'])) {
    foreach ($_POST['qty'] as $product => $quantity) {
        $quantity = (int)$quantity; [cite: 21]
        if ($quantity <= 0) {
            unset($_SESSION['cart'][$product]);
        } else {
            $_SESSION['cart'][$product] = $quantity;
        }
    }
    header("Location: cart.php");
    exit();
}
