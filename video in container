<!DOCTYPE html>
<html>
<head>
<title>Bean and Brew About Us</title>
<style>
/* --- Coffee Cup Video --- */
.cup-container {
  position: absolute;
  top: 150px;    /* adjust vertical position */
  right: 20px;   /* distance from right edge */
  width: 180px;  /* width of cup */
  height: 220px; /* height of cup */
  overflow: hidden; /* prevent overflow */
}
 
.cup-container video {
  width: 110%; /* slightly bigger to cover area */
  height: auto;
  object-fit: cover;
  object-position: center top; /* adjust as needed */
  position: relative;
  top: -15px; /* shift video upwards */
  left: -5px; /* shift video left */
  border-radius: 10px; /* optional */
}
 
.cup-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none; /* let video controls work */
  z-index: 2; /* on top */
}
 
/* Body background */
body {
  background-color: #331a00; 
  opacity: 1;
  background-repeat: no-repeat;
  background-attachment: fixed;  
  background-size: cover;
}
 
/* Second video (unchanged) */
.moveD {
  position: absolute;
  top: 435px;
  left: -4px;
}
 
.box2 {
  border: 1px solid;
  background-color: #4d2600;
  padding: 30px;
  box-shadow: 5px #888888;
  border-radius: 30px;
}
 
/* Navbar styles */
nav {
  background-color: #4d2600;
  padding: -20px;
}
 
nav ul {
  list-style-type: none;
  margin: 0;
  padding: 0;
  display: flex;
  justify-content: center;
  gap: 20px;
}
 
nav a {
  text-decoration: none;
  color: #d2a679;
  font-weight: bold;
}
 
nav a.active {
  color: #ffdd99;
  border-bottom: 2px solid #b36b00;
}
 
</style>
</head>
<body>
 
<!-- Navbar -->
